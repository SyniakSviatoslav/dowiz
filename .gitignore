!secrets/*.env.example
keys.txt
*.agekey
# agentic-system local runtime state (not committed)
.claude/state/
.claude/logs/
.audit/
# E2E auth state — live signed JWTs / storage state written by the lifecycle harness.
# NEVER commit (ADR-0003 #7): these are real bearer tokens valid until expiry.
.auth/
**/.auth/

# harness tune-up local backups (large, never commit)
.harness-backups/

# Doubt model: loop-detector counters (ephemeral, per-session)
.claude/.loop-state/

# RSI synthetic-user loop — runtime artifacts (generated, never committed)
e2e/mempalace/*.jsonl
e2e/mempalace/*.json
e2e/findings/*.json
e2e/findings/traces/
e2e/findings/videos/
e2e/findings/transcripts/

e2e/findings/round-*/

# Session debris — test/polish screenshots, scratch probes, editor backups, tool output.
# Generated by agent sessions; never tracked.
/*.png
.polish/
scratch-*.mjs
.claude/*.bak-*
graphify-out/
# Audit-session screenshot evidence (800+ files) + per-app screenshot debris
/audit/
apps/api/*.png
# Loop-harness run artifacts + prospect packets (generated, may carry business contacts)
# P2 (meta-loop 2026-07-02): the design doc promises "permanent + lossless" run history, but the
# whole dir was ignored — history lived only on one VM. The compact metrics/routing/registry
# files are now tracked; the heavy gz run-records and business-contact packets stay local.
loops/runs/*
!loops/runs/metrics.jsonl
!loops/runs/routing.jsonl
!loops/runs/registry.json
# NOTE (ADR-plane-telemetry-and-calibration, R2-C1/R2-M5): plane-telemetry durability does NOT
# live here. loops/runs/ stays disposable scratch (per-box working copy). The authoritative,
# append-only record is committed to a DEDICATED orphan branch `telemetry/plane` under a clean
# telemetry/ path via git plumbing — never onto main, never into this scratch dir.
loops/prospects/
# Committed-by-accident classes: log dumps at root, python bytecode
/*.txt
__pycache__/
*.pyc
# NVIDIA SkillSpector — operator security tool (agent-skill scanner), not app code
tools/skillspector/

# offer-builder output packets contain business contact info (public, but keep outreach targets out of git)
loops/offers/
