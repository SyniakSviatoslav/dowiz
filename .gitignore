# agentic-system local runtime state (not committed)
.claude/state/
.claude/logs/
.audit/
# E2E auth state — live signed JWTs / storage state written by the lifecycle harness.
# NEVER commit (ADR-0003 #7): these are real bearer tokens valid until expiry.
.auth/
**/.auth/

# harness tune-up local backups (large, never commit)
.harness-backups/

# Doubt model: loop-detector counters (ephemeral, per-session)
.claude/.loop-state/

# RSI synthetic-user loop — runtime artifacts (generated, never committed)
e2e/mempalace/*.jsonl
e2e/mempalace/*.json
e2e/findings/*.json
e2e/findings/traces/
e2e/findings/videos/
e2e/findings/transcripts/

e2e/findings/round-*/

# Session debris — test/polish screenshots, scratch probes, editor backups, tool output.
# Generated by agent sessions; never tracked.
/*.png
.polish/
scratch-*.mjs
.claude/*.bak-*
graphify-out/
# NVIDIA SkillSpector — operator security tool (agent-skill scanner), not app code
tools/skillspector/

# offer-builder output packets contain business contact info (public, but keep outreach targets out of git)
loops/offers/
