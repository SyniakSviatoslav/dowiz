# pgrust.env — environment file for the pgrust native systemd service.
#
# DK-05. NO SECRETS here — only non-sensitive runtime knobs. Credentials (DB
# passwords, key material) are injected out-of-band via the real deployment
# secret store, NOT committed to this file.
#
# Loaded by pgrust.service via EnvironmentFile=/etc/pgrust/pgrust.env

# Listen address:host for the pgrust wire protocol. 127.0.0.1 by default —
# front it with PgBouncer (native sidecar) for connection pooling / client
# multiplexing rather than exposing pgrust directly to tenants.
PGRUST_LISTEN=127.0.0.1:5432

# Data directory (must match ReadWritePaths in pgrust.service + data_dir in
# pgrust.toml).
PGRUST_DATA_DIR=/var/lib/pgrust

# Log level (info|debug|warn|error).
PGRUST_LOG=info

# RLS cross-tenant enforcement toggle — MUST stay "deny". The app-level RLS
# gate is the real tenant-isolation boundary for pgrust (DK-05 blueprint).
PGRUST_RLS_CROSS_TENANT=deny

# Optional: native PgBouncer sidecar address pgrust should register with.
# PGRUST_POOLER=127.0.0.1:6432
