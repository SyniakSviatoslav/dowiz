NODE_ENV=development
PORT=8080
APP_BASE_URL=
DATABASE_URL_OPERATIONAL=postgresql://your-user:your-pass@your-host:5432/your-db
DATABASE_URL_SESSION=postgresql://your-user:your-pass@your-host:5432/your-db
DATABASE_URL_MIGRATIONS=postgresql://your-user:your-pass@your-host:5432/your-db
REDIS_URL=redis://your-redis-host:6379
# RS256 key pair (required — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
# Then set as single-line secrets on Fly.io: flyctl secrets set JWT_PRIVATE_KEY="$(cat private.pem)" JWT_PUBLIC_KEY="$(cat public.pem)"
JWT_PRIVATE_KEY=your-rsa-private-key-pem
JWT_PUBLIC_KEY=your-rsa-public-key-pem
JWT_KID=v1
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_SECRET=your-telegram-webhook-secret
TELEGRAM_BOT_USERNAME=your_bot_username

# WhatsApp notifications (Baileys — unofficial WhatsApp Web protocol, no browser)
# Set WHATSAPP_ENABLED=true to activate; on first run scan the QR printed to the
# API logs with WhatsApp on the owner's phone. Session is persisted in WHATSAPP_AUTH_DIR.
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=./.whatsapp-auth

# PII hashing salt (required in production for deterministic SHA-256 hashing)
IP_HASH_SALT=