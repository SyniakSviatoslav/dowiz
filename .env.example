NODE_ENV=development
PORT=8080
APP_BASE_URL=
***REDACTED***=postgresql://your-user:your-pass@your-host:5432/your-db
***REDACTED***=postgresql://your-user:your-pass@your-host:5432/your-db
***REDACTED***=postgresql://your-user:your-pass@your-host:5432/your-db
REDIS_URL=redis://your-redis-host:6379
# RS256 key pair (required — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
# Then set as single-line secrets on Fly.io: flyctl secrets set ***REDACTED***="$(cat private.pem)" ***REDACTED***="$(cat public.pem)"
***REDACTED***=your-rsa-private-key-pem
***REDACTED***=your-rsa-public-key-pem
JWT_KID=v1
***REDACTED***=your-google-client-id
***REDACTED***=your-google-client-secret
***REDACTED***=your-telegram-bot-token
***REDACTED***=your-telegram-webhook-secret
TELEGRAM_BOT_USERNAME=your_bot_username

# WhatsApp notifications (Baileys — unofficial WhatsApp Web protocol, no browser)
# Set WHATSAPP_ENABLED=true to activate; on first run scan the QR printed to the
# API logs with WhatsApp on the owner's phone. Session is persisted in ***REDACTED***.
WHATSAPP_ENABLED=false
***REDACTED***=./.whatsapp-auth

# PII hashing salt (required in production for deterministic SHA-256 hashing)
IP_HASH_SALT=