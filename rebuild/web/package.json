{
  "name": "@deliveryos-rebuild/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Phase A spike: Astro 5 + Svelte 5 islands storefront shell for the DeliveryOS Rust rebuild. Self-contained package, not part of the root pnpm workspace.",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "gen:messages": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy globalVariable baseLocale",
    "prebuild": "pnpm run gen:messages"
  },
  "dependencies": {
    "@astrojs/node": "9.5.5",
    "@astrojs/svelte": "7.2.5",
    "@inlang/paraglide-js": "2.20.2",
    "astro": "5.18.2",
    "svelte": "5.56.4"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3"
  }
}
