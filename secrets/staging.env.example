# Template for the local-dev secrets bundle. COPY to a working file, fill REAL values, then encrypt:
#
#   cp secrets/staging.env.example secrets/staging.env      # fill values (gitignored, never committed)
#   sops -e --input-type dotenv --output-type dotenv secrets/staging.env > secrets/staging.enc.env
#   rm secrets/staging.env                                  # only the .enc.env is committed
#
# Load into a shell:  source scripts/secrets-env.sh staging
#
# This is the local-dev essentials, NOT the full set. Canonical list: packages/config/src/index.ts
# (Zod schema) + compliance/env-classification.md. Runtime prod/staging still read from Fly Secrets.
ENV=staging
APP_BASE_URL=https://dowiz-staging.fly.dev

# Auth / signing (internal)
DEV_AUTH_SECRET=
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_DEV_PRIVATE_KEY=
JWT_DEV_PUBLIC_KEY=

# Provisioning ops gate (internal) — the /internal/acquisition surface
PROVISION_OPS_SECRET=

# Crypto / PII (internal)
BACKUP_ENCRYPTION_KEY=
COURIER_PII_ENCRYPTION_KEY=
IP_HASH_SALT=

# Web push (internal)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Data plane (internal)
DATABASE_URL_OPERATIONAL=
DATABASE_URL_SESSION=
REDIS_URL=

# External subprocessors (fill only if used locally — see compliance/subprocessors.md)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_SECRET=
OPENROUTER_API_KEY=
OPENCODE_ZEN_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=
RESEND_API_KEY=
ROUTING_API_KEY=
SENTRY_DSN=
GOOGLE_CLIENT_SECRET=
