-criterion_group!(benches, bench_loop_cycle_benign, bench_wire_benign);
+/// Bus publish fan-out throughput (G-C1 snapshot-under-lock fix). Confirms the
+/// `Arc`-snapshot / dispatch-outside-lock rewrite does not regress the single-publish
+/// happy path (8 subscribers on one topic; each publish snapshots + dispatches to all).
+/// The fix's real win — concurrent publishes no longer serialize behind the bus lock,
+/// and re-entrant handlers no longer deadlock — is proven by the `portkey`/`zenoh`
+/// unit tests (`reentrant_handler_does_not_deadlock`, `publish_preserves_order_...`).
+fn bench_portkey_publish_fanout(c: &mut Criterion) {
+    use bebop::portkey::{Envelope, Portkey};
+    use std::sync::atomic::{AtomicUsize, Ordering};
+    use std::sync::Arc;
+
+    let bus = Portkey::new();
+    let hits = Arc::new(AtomicUsize::new(0));
+    for _ in 0..8 {
+        let h = hits.clone();
+        bus.subscribe("telemetry", move |_| {
+            h.fetch_add(1, Ordering::Relaxed);
+        });
+    }
+    let env = Envelope {
+        topic: "telemetry".into(),
+        from: "sensor".into(),
+        to: "".into(),
+        body: "tick".into(),
+    };
+    c.bench_function("portkey/publish_fanout_8subs", |b| {
+        b.iter(|| black_box(bus.publish(black_box(&env))))
+    });
+}
+
+criterion_group!(
+    benches,
+    bench_loop_cycle_benign,
+    bench_wire_benign,
+    bench_portkey_publish_fanout
+);
 criterion_main!(benches);
