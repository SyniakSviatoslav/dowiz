{
  "name": "deliveryos-monorepo",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.4.0",
  "pnpm": {
    "overrides": {
      "form-data@<4.0.6": ">=4.0.6",
      "undici@<6.27.0": ">=6.27.0"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:gates": "eslint --no-ignore tools/eslint-plugin-local/__fixtures__/*",
    "format": "prettier --write .",
    "verify:env": "tsx --env-file=.env packages/config/src/verify-env.ts",
    "verify:db": "pnpm --filter @deliveryos/db run verify:db",
    "seed": "tsx --env-file=.env packages/db/scripts/seed.ts",
    "verify:rls": "tsx --env-file=.env packages/db/scripts/verify-rls.ts",
    "verify:migrations": "tsx scripts/verify-migrations.ts",
    "verify:fresh-provision": "bash scripts/verify-fresh-provision.sh",
    "compliance:gate": "tsx scripts/compliance-gate.ts",
    "guardrail:owner-active": "node scripts/guardrail-owner-active-membership.mjs",
    "guardrail:spike-boundary": "node scripts/guardrail-spike-boundary.mjs",
    "guardrail:deliver-v2": "node scripts/guardrail-deliver-v2.mjs",
    "guardrail:corpus-reachability": "node scripts/guardrail-corpus-reachability.mjs",
    "guardrail:license": "node scripts/guardrail-license.mjs",
    "guardrail:hook-matchers": "node scripts/guardrail-hook-matchers.mjs",
    "verify:all": "tsx scripts/verify-all.ts",
    "test:unit": "node --test --import tsx 'apps/api/tests/**/*.test.ts' 'apps/worker/tests/**/*.test.ts' 'apps/web/src/**/*.test.ts' 'packages/**/*.test.ts' 'tools/**/tests/**/*.test.ts'",
    "backup:restore": "tsx --env-file=.env scripts/backup-restore.ts",
    "migrate:create": "node-pg-migrate create -j ts -m packages/db/migrations",
    "migrate:up": "node-pg-migrate up --no-check-order -d DATABASE_URL_MIGRATIONS -j ts -m packages/db/migrations --envPath .env --tsx --tsconfig tsconfig.migrations.json",
    "migrate:down": "node-pg-migrate down -d DATABASE_URL_MIGRATIONS -j ts -m packages/db/migrations --envPath .env --tsx --tsconfig tsconfig.migrations.json",
    "bundle": "tsx scripts/build-apps.ts",
    "dev:api:1": "cross-env PORT=3000 pnpm --filter @deliveryos/api run dev",
    "dev:api:2": "cross-env PORT=3001 pnpm --filter @deliveryos/api run dev",
    "dev:worker": "pnpm --filter @deliveryos/worker run dev",
    "dev:ui": "npx serve src/screens -p 3001",
    "dev:all": "npx concurrently \"pnpm run dev:api:1\" \"pnpm run dev:worker\" \"pnpm run dev:ui\"",
    "test:phase0": "tsx --env-file=.env apps/api/tests/test-phase0.ts",
    "test:phase4-step0": "tsx --env-file=.env apps/api/tests/test-stage23.ts",
    "test:phase4-step1": "tsx --env-file=.env apps/api/tests/test-stage24.ts",
    "test:phase4": "tsx --env-file=.env apps/api/tests/test-stage25.ts && tsx --env-file=.env apps/api/tests/test-stage26.ts && tsx --env-file=.env apps/api/tests/test-stage27.ts && tsx --env-file=.env apps/api/tests/test-stage28.ts && tsx --env-file=.env apps/api/tests/test-stage29.ts",
    "test:phase5-step0": "tsx --env-file=.env apps/api/tests/test-stage30.ts",
    "test:phase5-step1": "tsx --env-file=.env apps/api/tests/test-stage31.ts",
    "test:phase5-step2": "tsx --env-file=.env apps/api/tests/test-stage32.ts",
    "test:phase5-step3": "tsx --env-file=.env apps/api/tests/test-stage33.ts",
    "test:phase5-step4": "tsx --env-file=.env apps/api/tests/test-stage34.ts",
    "test:phase5-step5": "tsx --env-file=.env apps/api/tests/test-stage35.ts",
    "test:phase5": "tsx --env-file=.env apps/api/tests/test-stage30.ts && tsx --env-file=.env apps/api/tests/test-stage31.ts && tsx --env-file=.env apps/api/tests/test-stage32.ts && tsx --env-file=.env apps/api/tests/test-stage33.ts && tsx --env-file=.env apps/api/tests/test-stage34.ts && tsx --env-file=.env apps/api/tests/test-stage35.ts",
    "test:nx-notification-infra": "tsx --env-file=.env apps/api/tests/test-stage36.ts",
    "verify:secrets": "tsx scripts/verify-secrets.ts",
    "free-tier:watch": "tsx --env-file=.env scripts/free-tier-watch.ts",
    "verify:launch": "tsx --env-file=.env scripts/verify-launch.ts",
    "test:phase5-rls-adversarial": "tsx --env-file=.env apps/api/tests/phase5/rls-adversarial.test.ts",
    "test:phase5-jwt-rotation": "tsx --env-file=.env apps/api/tests/phase5/jwt-rotation.test.ts",
    "test:phase5-integrity": "tsx --env-file=.env apps/api/tests/phase5/integrity.test.ts",
    "backup:verify": "tsx --env-file=.env scripts/backup-verify.ts",
    "backup:drill": "tsx --env-file=.env scripts/backup-drill.ts",
    "backup:list": "tsx --env-file=.env scripts/backup-list.ts",
    "test:phase2+phase3+phase4+phase5-step0": "tsx --env-file=.env apps/api/tests/test-phase2.ts && tsx --env-file=.env apps/api/tests/test-phase0.ts && tsx --env-file=.env apps/api/tests/test-stage7.ts && tsx --env-file=.env apps/api/tests/test-stage9.ts && tsx --env-file=.env apps/api/tests/test-stage10.ts && tsx --env-file=.env apps/api/tests/test-stage11.ts && tsx --env-file=.env apps/api/tests/test-stage12.ts && tsx --env-file=.env apps/api/tests/test-stage13.ts && tsx --env-file=.env apps/api/tests/test-stage17.ts && tsx --env-file=.env apps/api/tests/test-stage18.ts && tsx --env-file=.env apps/api/tests/test-stage19.ts && tsx --env-file=.env apps/api/tests/test-stage20.ts && tsx --env-file=.env apps/api/tests/test-stage23.ts && tsx --env-file=.env apps/api/tests/test-stage24.ts && tsx --env-file=.env apps/api/tests/test-stage25.ts && tsx --env-file=.env apps/api/tests/test-stage26.ts && tsx --env-file=.env apps/api/tests/test-stage27.ts && tsx --env-file=.env apps/api/tests/test-stage28.ts && tsx --env-file=.env apps/api/tests/test-stage29.ts && tsx --env-file=.env apps/api/tests/test-stage30.ts",
    "verify:nx": "tsx --env-file=.env apps/api/scripts/verify-nx-flow.ts",
    "verify:i18n-coverage": "tsx apps/api/scripts/verify-i18n-coverage.ts",
    "verify:contrast": "tsx apps/api/scripts/verify-contrast.ts",
    "verify:error-contract": "tsx apps/api/scripts/verify-error-contract.ts",
    "verify:ccc-secrets": "node --test --import tsx tools/ccc/tests/secret-scan.test.ts",
    "verify:menu-parse": "tsx apps/api/tests/menu-parse/run.ts",
    "ccc": "tsx tools/ccc/src/cli.ts",
    "verify:event-wiring": "tsx --env-file=.env apps/api/scripts/verify-event-wiring.ts",
    "verify:schema-queries": "tsx --env-file=.env apps/api/scripts/verify-schema-queries.ts",
    "verify:connection-lifecycle": "tsx scripts/verify-connection-lifecycle.ts",
    "verify:n2": "tsx --env-file=.env apps/api/tests/verify-n2.ts",
    "verify:privacy": "tsx --env-file=.env apps/api/tests/pii-leak-detector.test.ts",
    "check:core": "RUN_ID=dev node metric-core/run-checks.mjs",
    "check:core:ci": "CI=true RUN_ID=$RUN_ID node metric-core/run-checks.mjs",
    "size:check": "size-limit",
    "lhci": "lhci autorun",
    "storefront:guard": "node scripts/storefront-graph-guard.mjs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@lhci/cli": "^0.14.0",
    "@langfuse/otel": "^5.4.1",
    "@opencode-ai/plugin": "1.15.11",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.219.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.10.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-local": "workspace:*",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "node-pg-migrate": "^8.0.4",
    "@size-limit/file": "^11.2.0",
    "size-limit": "^11.2.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.5.0",
    "ws": "^8.21.0"
  },
  "dependencies": {
    "maplibre-gl": "^5.24.0"
  }
}
