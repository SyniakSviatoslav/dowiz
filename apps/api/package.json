{
  "name": "@deliveryos/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node build-client.js && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/server.js",
    "dev": "concurrently \"node build-client.js --watch\" \"tsx --env-file=../../.env src/server.ts\"",
    "test:phase2": "node --test --import tsx tests/test-phase2.ts",
    "verify:n2:phase2": "tsx tests/verify-n2.ts",
    "test:e2e:phase2": "playwright test e2e/phase2.spec.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-storage": "^3.1058.0",
    "@deliveryos/config": "workspace:*",
    "@deliveryos/db": "workspace:^",
    "@deliveryos/domain": "workspace:*",
    "@deliveryos/platform": "workspace:^",
    "@deliveryos/shared-types": "workspace:*",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "@sentry/node": "^9.0.0",
    "@types/pg": "^8.20.0",
    "argon2": "^0.44.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "fastify-type-provider-zod": "^6.1.0",
    "htm": "^3.1.1",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "lru-cache": "^11.5.1",
    "mem0ai": "^3.0.6",
    "pdf-parse": "1.1.1",
    "pg": "^8.21.0",
    "pg-boss": "^12.18.2",
    "pino": "^9.14.0",
    "preact": "^10.29.2",
    "preact-render-to-string": "^6.7.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.0",
    "playwright": "^1.60.0",
    "typescript": "^5.6.2"
  }
}
