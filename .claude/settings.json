{
 "permissions": {
  "allow": [
   "Bash(*)",
   "Edit(*)",
   "Write(*)",
   "MultiEdit(*)",
   "Read(*)",
   "Glob(*)",
   "Grep(*)",
   "PowerShell(*)",
   "WebFetch",
   "WebSearch",
   "Agent",
   "Task",
   "Skill",
   "TodoWrite",
   "NotebookEdit",
   "ToolSearch",
   "Workflow",
   "Monitor",
   "mcp__repowise",
   "mcp__playwright-test",
   "mcp__browser-use",
   "mcp__figma-remote-mcp"
  ],
  "deny": []
 },
 "hooks": {
  "PreToolUse": [
   {
    "matcher": "Edit|Write|MultiEdit",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/protect-paths.sh\""
     }
    ]
   },
   {
    "matcher": "Edit|Write|MultiEdit",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-edit-lessons.sh\""
     }
    ]
   },
   {
    "matcher": "Edit|Write|MultiEdit",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/red-line-doubt-gate.sh\""
     }
    ]
   },
   {
    "matcher": "Bash",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-bash.sh\""
     }
    ]
   },
   {
    "matcher": "Agent|Task",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/agent-dispatch-gate.sh\""
     }
    ]
   }
  ],
  "PostToolUse": [
   {
    "matcher": "Edit|Write|MultiEdit",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-gates.sh\""
     }
    ]
   },
   {
    "matcher": "Bash|Edit|Write|MultiEdit",
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/loop-detector.sh\""
     }
    ]
   }
  ],
  "UserPromptSubmit": [
   {
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/route-request.sh\""
     }
    ]
   },
   {
    "hooks": [
     {
      "type": "command",
      "command": "CONTEXT_WINDOW=1000000 CONTEXT_BUDGET_PCT=30 bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/context-budget-guard.sh\""
     }
    ]
   }
  ],
  "Stop": [
   {
    "hooks": [
     {
      "type": "command",
      "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/require-classification.sh\""
     }
    ]
   }
  ]
 }
}
