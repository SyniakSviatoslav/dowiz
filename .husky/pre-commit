echo "=== Running Pre-commit Checks ==="

echo "1/4: Linting staged files..."
STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' | tr '\n' ' ')
if [ -n "$STAGED" ]; then
  npx eslint $STAGED || exit 1
else
  echo "No JS/TS staged files to lint."
fi

echo "1.4: injection-corpus reachability (whole-tree, blocking — tooling-integration-eval G1)..."
node scripts/guardrail-corpus-reachability.mjs || exit 1

echo "1.4b: license + forbidden-dep + env-classification (whole-tree, blocking — tooling-integration-eval G5)..."
node scripts/guardrail-license.mjs || exit 1

echo "1.4c: hook matchers cover all edit tools (no gate bypass via MultiEdit)..."
node scripts/guardrail-hook-matchers.mjs || exit 1

echo "1.4d: governance armaments armed, not just registered (gates can still deny; no rot off the runner)..."
bash scripts/run-armaments.sh || exit 1

echo "1.4e: module-integrity (module.toml manifests match the real cargo dependency graph)..."
if command -v cargo >/dev/null 2>&1; then
  node scripts/module-integrity.mjs || exit 1
else
  echo "cargo not installed — skipping the crate-dep reality check (self-test still ran in 1.4d; CI enforces the full gate)."
fi

echo "1.4f: legacy-api freeze (strangled Node shell apps/api may not grow route registrations)..."
node scripts/guardrail-legacy-freeze.mjs || exit 1

echo "1.4g: connected islands — security/hygiene guardrails that ran NOWHERE are now enforced (brain-in-brain finding 2026-07-07: an unrun guardrail is a false-positive green)..."
node scripts/guardrail-definer-search-path.mjs || exit 1   # SECURITY DEFINER search_path pinning (RLS-bypass)
node scripts/guardrail-no-set-cookie.mjs || exit 1         # bearer-only / CSRF-free posture
node scripts/guardrail-sandbox-staleness.mjs || exit 1     # sandbox worktree data-loss guard

echo "1.5: i18n parity (no missing/TODO translations)..."
if git diff --cached --name-only --diff-filter=ACM | grep -qE 'packages/ui/src/lib/i18n(-catalog)?\.ts$'; then
  pnpm exec tsx scripts/i18n-parity.ts || exit 1
else
  echo "No i18n changes staged."
fi

# ── DYNAMIC VERIFICATION SCOPE (operator 2026-07-07: "if a change does not require a full build, no
# point running all verifications + container build"). Deterministic check on the STAGED PATHS: the
# heavy steps (typecheck / build / Fly / Docker) can only fail from a change to the built artifact —
# app/package code or build config. A docs/.claude/loops/tooling-only change cannot, so we skip them
# and save minutes (this once TIMED OUT on a .claude-only commit). INCLUSIVE by design: ANY match →
# full build. The cheap whole-tree guardrails above ALWAYS ran regardless (they protect repo
# integrity for free). Escape hatch: FORCE_FULL_PRECOMMIT=1 forces the full path. This is the harness
# scaling its own verification depth to the actual change — deterministic, not a guess.
BUILD_RELEVANT=$(git diff --cached --name-only --diff-filter=ACMRD | grep -E '^(apps|packages)/|(^|/)(package\.json|pnpm-lock\.yaml|pnpm-workspace\.yaml|Dockerfile|\.dockerignore|fly\.toml)$|(^|/)tsconfig[^/]*\.json$|(^|/)vite\.config\.[tj]s$' || true)
if [ "${FORCE_FULL_PRECOMMIT:-0}" != "1" ] && [ -z "$BUILD_RELEVANT" ]; then
  echo "2-5/5: no build-relevant files staged (docs/.claude/loops/tooling only) — skipping typecheck, build, Fly + Docker. [dynamic-scope; FORCE_FULL_PRECOMMIT=1 to override]"
  echo "=== All checks passed! ==="
  exit 0
fi
echo "Build-relevant change detected — running full typecheck/build/Docker verification:"
printf '  %s\n' $BUILD_RELEVANT | head -8

echo "2/4: Typechecking code..."
pnpm -r typecheck || exit 1

echo "3/4: Building packages and apps..."
pnpm -r build || exit 1

echo "4/5: Validating Fly.io config..."
if command -v flyctl >/dev/null 2>&1 || command -v fly >/dev/null 2>&1; then
  flyctl config validate || fly config validate || exit 1
  echo "Fly.io config is valid!"
else
  echo "Fly CLI not found. Skipping config validation."
fi

echo "5/5: Checking Fly.io Build (Docker)..."
if command -v docker >/dev/null 2>&1; then
  # DISK GUARD (regression fix — docs/incidents/2026-06-28-local-pg-disk-crash.md): Docker shares /dev/sda1
  # with the local Postgres data dir; the per-commit build orphans layers, and ~50 commits once filled the
  # disk and crashed PG into WAL-recovery. Reclaim to a free-space target BEFORE the build (tiered, safe),
  # skip the build if still too low, and reclaim again AFTER to drop the layer this build just orphaned.
  bash scripts/docker-disk-guard.sh 15
  AVAIL_GB=$(df -BG --output=avail / 2>/dev/null | tail -1 | tr -dc '0-9')
  if [ -n "$AVAIL_GB" ] && [ "$AVAIL_GB" -lt 8 ]; then
    echo "Low disk (${AVAIL_GB}G free after prune) — skipping the local Docker build to protect the disk (cloud build still gates deploy)."
  elif docker build -t dowiz-check . 2>&1; then
    echo "Fly.io (Docker) build successful!"
  else
    echo "Warning: Docker build failed (local network/env issue). Fly.io builds in cloud — skipping."
  fi
  bash scripts/docker-disk-guard.sh 20
else
  echo "Docker is not installed or not running. Skipping Fly.io build check."
fi

echo "=== All checks passed! ==="
