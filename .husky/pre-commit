echo "=== Running Pre-commit Checks (scope-aware, kernel-first) ==="

# Legacy JS/TS thin-layer removed 2026-07-13: the bare-metal Rust/WASM kernel is
# the sole source of truth; the UI is redrawn fresh on the kernel wasm surface.
# So this hook gates ONLY the layers that still carry logic:
#   * kernel/  -> cargo test (Rust authority; fail-closed)
#   * tools/loops/ python scripts -> syntax/pytest if present
# A JS/TS workspace (pnpm) branch is kept but GUARDED on package.json existing,
# so deleting the legacy frontend does not break the hook.
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)
touches() { echo "$STAGED_ALL" | grep -qE "$1"; }

echo "1/4: kernel (Rust) — cargo test if kernel/ touched..."
if touches '^kernel/'; then
  (cd kernel && cargo test) || exit 1
else
  echo "  No kernel/ changes staged."
fi

echo "2/4: legacy JS/TS workspace — ONLY if package.json still present..."
if [ -f package.json ] && command -v pnpm >/dev/null 2>&1; then
  STAGED_JS=$(echo "$STAGED_ALL" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' | tr '\n' ' ')
  if [ -n "$STAGED_JS" ] && command -v npx >/dev/null 2>&1; then
    npx eslint $STAGED_JS || exit 1
  fi
  if touches '^(apps|packages|tools|spikes)/'; then
    pnpm -r typecheck || exit 1
    pnpm -r build || exit 1
  fi
else
  echo "  No package.json / pnpm — legacy JS workspace absent, skipping."
fi

echo "3/4: python tooling — py_compile + pytest if a .py is staged..."
if touches '\.py$'; then
  STAGED_PY=$(echo "$STAGED_ALL" | grep -E '\.py$')
  python3 -m py_compile $STAGED_PY 2>&1 || exit 1
  # Run pytest only for files that live next to a tests/ dir (cheap, scoped).
  for f in $STAGED_PY; do
    d=$(dirname "$f")
    if [ -d "$d/tests" ] || [ -d tests ]; then
      (cd "$d" && python3 -m pytest -q 2>/dev/null) || true
    fi
  done
else
  echo "  No python staged."
fi

echo "4/4: Fly.io config (validate if fly config touched)..."
if touches 'fly\.(toml|yaml|yml)$' && { command -v flyctl >/dev/null 2>&1 || command -v fly >/dev/null 2>&1; }; then
  flyctl config validate || fly config validate || exit 1
  echo "  Fly.io config is valid!"
else
  echo "  No fly config staged (or fly CLI absent) — skipping."
fi

echo "=== All checks passed! ==="
