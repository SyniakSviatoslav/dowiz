echo "=== Running Pre-commit Checks (scope-aware) ==="

# What is actually staged? Route checks to the affected scope so a web/-only or
# kernel/-only commit does not pay for a full monorepo build (the workspace
# globs in pnpm-workspace.yaml are apps/* packages/* tools/* spikes/* — web/ and
# kernel/ are NOT workspace members). fail-closed: every touched scope is still
# gated, we just run the RIGHT gate instead of `pnpm -r build` for everything.
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)
touches() { echo "$STAGED_ALL" | grep -qE "$1"; }

echo "1/5: Linting staged JS/TS files..."
STAGED_JS=$(echo "$STAGED_ALL" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' | tr '\n' ' ')
if [ -n "$STAGED_JS" ]; then
  npx eslint $STAGED_JS || exit 1
else
  echo "  No JS/TS staged files to lint."
fi

echo "1.5: i18n parity (no missing/TODO translations)..."
if touches 'packages/ui/src/lib/i18n(-catalog)?\.ts$'; then
  pnpm exec tsx scripts/i18n-parity.ts || exit 1
else
  echo "  No i18n changes staged."
fi

echo "2/5: kernel (Rust) — cargo test if kernel/ touched..."
if touches '^kernel/'; then
  (cd kernel && cargo test) || exit 1
else
  echo "  No kernel/ changes staged."
fi

echo "3/5: web (Astro island) — build if web/ touched..."
if touches '^web/'; then
  (cd web && npx astro build) || exit 1
  # If the shared kernel wasm glue changed, also run its node equivalence test.
  if touches '^web/src/lib/kernel/'; then
    (cd web/src/lib/kernel && node kernel.test.mjs) || exit 1
  fi
else
  echo "  No web/ changes staged."
fi

echo "4/5: workspace packages/apps — typecheck+build ONLY if a workspace member is touched..."
if touches '^(apps|packages|tools|spikes)/'; then
  pnpm -r typecheck || exit 1
  pnpm -r build || exit 1
else
  echo "  No workspace (apps/packages/tools/spikes) changes staged — skipping monorepo build."
fi

echo "5/5: Fly.io config (validate if fly config touched)..."
if touches 'fly\.(toml|yaml|yml)$' && { command -v flyctl >/dev/null 2>&1 || command -v fly >/dev/null 2>&1; }; then
  flyctl config validate || fly config validate || exit 1
  echo "  Fly.io config is valid!"
else
  echo "  No fly config staged (or fly CLI absent) — skipping."
fi

echo "=== All checks passed! ==="
