#!/usr/bin/env bash
set -euo pipefail
echo "=== Running Pre-commit Checks (scope-aware, kernel-first) ==="
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM)
touches() { echo "$STAGED_ALL" | grep -qE "$1"; }

echo "1/5: gitleaks — secret scan on staged files..."
if [ -n "$STAGED_ALL" ] && command -v gitleaks >/dev/null 2>&1; then
  if ! gitleaks protect --staged 2>/dev/null; then
    echo "::error::gitleaks: possible secret detected in staged files — aborting commit"
    exit 1
  fi
  echo "  gitleaks: clean"
else
  echo "  Skipped (no staged / gitleaks not installed)"
fi

echo "2/5: kernel (Rust) — cargo test if kernel/ touched..."
if touches '^kernel/'; then
  (cd kernel && cargo test) || exit 1
else
  echo "  No kernel/ changes staged."
fi

echo "3/5: cargo-deny — ban yanked + wildcards + licenses if any Cargo.toml/Cargo.lock staged..."
if touches 'Cargo\\.(toml|lock)$' && command -v cargo-deny >/dev/null 2>&1; then
  (cd kernel && cargo-deny check) || exit 1
else
  echo "  No Cargo.* staged, or cargo-deny not installed."
fi

echo "4/5: python tooling — syntax + pytest if .py staged..."
if touches '\\.py$'; then
  STAGED_PY=$(echo "$STAGED_ALL" | grep -E '\.py$')
  python3 -m py_compile $STAGED_PY 2>&1 || exit 1
  for f in $STAGED_PY; do
    d=$(dirname "$f")
    if [ -d "$d/tests" ] || [ -d tests ]; then
      (cd "$d" && python3 -m pytest -q 2>/dev/null) || true
    fi
  done
else
  echo "  No python staged."
fi

echo "5/5: Fly.io config (validate if fly config touched)..."
if touches 'fly\\.(toml|yaml|yml)$' && { command -v flyctl >/dev/null 2>&1 || command -v fly >/dev/null 2>&1; }; then
  flyctl config validate || fly config validate || exit 1
  echo "  Fly.io config is valid!"
else
  echo "  No fly config staged (or fly CLI absent) — skipping."
fi

echo "=== All checks passed! ==="
